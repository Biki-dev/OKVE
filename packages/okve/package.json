{
	"name": "@biki-dev/okve",
	"version": "0.5.1",
	"private": false,
	"type": "module",
	"description": "Open Knowledge Visualization Engine, a reusable React knowledge graph component.",
	"main": "./dist/okve.cjs",
	"module": "./dist/okve.js",
	"types": "./dist/src/index.d.ts",
	"license": "MIT",
	"keywords": [
		"react",
		"graph",
		"visualization",
		"knowledge-graph",
		"d3",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Biki-dev/OKVE.git"
	},
	"homepage": "https://github.com/Biki-dev/OKVE#readme",
	"bugs": {
		"url": "https://github.com/Biki-dev/OKVE/issues"
	},
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/okve.js",
			"require": "./dist/okve.cjs"
		},
		"./styles.css": "./dist/okve.css"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"d3": "^7.9.0"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/d3": "^7.4.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"typescript": "^6.0.0",
		"vite": "^8.0.1",
		"vite-plugin-dts": "^4.5.4"
	}
}
